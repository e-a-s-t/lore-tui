{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "rustc@latest",
    "cargo@latest",
    "rustfmt@latest",
    "clippy@latest",
    "pkg-config@latest",
    "openssl@latest",
    "git@latest",
    "jq@latest"
  ],
  "shell": {
    "scripts": {
      "run-tui": "cargo run -p lore-tui",
      "run-cli": "cargo run -p lore-cli",

      "build": "cargo build --workspace",
      "test": "cargo test --workspace",
      "fmt": "cargo fmt --all",
      "check": "cargo check --workspace",
      "lint": "cargo clippy --workspace --all-targets -- -D warnings",

      "build-tui": "cargo build -p lore-tui",
      "test-tui": "cargo test -p lore-tui",
      "check-tui": "cargo check -p lore-tui",

      "build-cli": "cargo build -p lore-cli",
      "test-cli": "cargo test -p lore-cli",
      "check-cli": "cargo check -p lore-cli",

      "release-patch": "./scripts/release-patch.sh",
      "bump-minor": "./scripts/release-minor.sh",
      "bump-major": "./scripts/release-major.sh"
    }
  }
}
