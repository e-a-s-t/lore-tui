{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "rustc@latest",
    "cargo@latest",
    "cargo-release@latest",
    "rustfmt@latest",
    "clippy@latest",
    "pkg-config@latest",
    "openssl@latest",
    "git@latest",
    "jq@latest",
    "ruby@latest"
  ],
  "shell": {
    "scripts": {
      "tui": "cargo run -p lore-tui",
      "cli": "cargo run -p lore-cli",

      "build": "cargo build --workspace",
      "test": "cargo test --workspace",
      "fmt": "cargo fmt --all",
      "check": "cargo check --workspace",
      "lint": "cargo clippy --workspace --all-targets -- -D warnings",

      "build-tui": "cargo build -p lore-tui",
      "test-tui": "cargo test -p lore-tui",
      "check-tui": "cargo check -p lore-tui",

      "build-cli": "cargo build -p lore-cli",
      "test-cli": "cargo test -p lore-cli",
      "check-cli": "cargo check -p lore-cli",

      "patch": "cargo release patch --no-publish --execute",
      "minor": "cargo release minor --no-publish --execute",
      "major": "cargo release major --no-publish --execute",

      "docs": "cd docs && gem install bundler -v '~> 2.5' && bundle _2.7.2_ install && bundle _2.7.2_ exec jekyll serve --host 0.0.0.0 --livereload --incremental",
      "docs-build": "cd docs && bundle _2.7.2_ exec jekyll build"
    }
  }
}
